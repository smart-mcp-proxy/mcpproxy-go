{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus data source scraping the mcpproxy /metrics endpoint",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }
  ],
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "schemaVersion": 39,
  "tags": ["mcpproxy", "observability"],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "label": "Data source",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0
      },
      {
        "name": "server",
        "label": "Upstream server",
        "type": "query",
        "datasource": "${datasource}",
        "query": "label_values(mcpproxy_tool_calls_total, server)",
        "includeAll": true,
        "multi": true,
        "refresh": 2,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "title": "MCPProxy Observability",
  "uid": "mcpproxy-observability",
  "panels": [
    {
      "type": "row",
      "title": "Overview",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "type": "stat",
      "title": "Uptime",
      "datasource": "${datasource}",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [{ "expr": "mcpproxy_uptime_seconds", "refId": "A" }]
    },
    {
      "type": "stat",
      "title": "Connected upstreams",
      "datasource": "${datasource}",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "targets": [{ "expr": "mcpproxy_servers_connected", "refId": "A" }]
    },
    {
      "type": "stat",
      "title": "Configured upstreams",
      "datasource": "${datasource}",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "targets": [{ "expr": "mcpproxy_servers_total", "refId": "A" }]
    },
    {
      "type": "stat",
      "title": "Quarantined upstreams",
      "datasource": "${datasource}",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] }
        },
        "overrides": []
      },
      "targets": [{ "expr": "mcpproxy_servers_quarantined", "refId": "A" }]
    },
    {
      "type": "stat",
      "title": "Indexed tools",
      "datasource": "${datasource}",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "targets": [{ "expr": "mcpproxy_tools_total", "refId": "A" }]
    },
    {
      "type": "stat",
      "title": "Active Docker containers",
      "datasource": "${datasource}",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "targets": [{ "expr": "mcpproxy_docker_containers_active", "refId": "A" }]
    },
    {
      "type": "row",
      "title": "Tool calls",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 }
    },
    {
      "type": "timeseries",
      "title": "Tool call rate (by status)",
      "datasource": "${datasource}",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "expr": "sum by (status) (rate(mcpproxy_tool_calls_total{server=~\"$server\"}[5m]))",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Tool call latency p95 (by server)",
      "datasource": "${datasource}",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, server) (rate(mcpproxy_tool_call_duration_seconds_bucket{server=~\"$server\"}[5m])))",
          "legendFormat": "{{server}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "HTTP & security",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 }
    },
    {
      "type": "timeseries",
      "title": "HTTP request rate (by status)",
      "datasource": "${datasource}",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 15 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "expr": "sum by (status) (rate(mcpproxy_http_requests_total[5m]))",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "OAuth refresh outcomes",
      "datasource": "${datasource}",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 15 },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "targets": [
        {
          "expr": "sum by (result) (rate(mcpproxy_oauth_refresh_total[15m]))",
          "legendFormat": "{{result}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Quarantine events",
      "datasource": "${datasource}",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 15 },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "targets": [
        {
          "expr": "sum by (scope, action) (rate(mcpproxy_quarantine_events_total[15m]))",
          "legendFormat": "{{scope}}/{{action}}",
          "refId": "A"
        }
      ]
    }
  ]
}
